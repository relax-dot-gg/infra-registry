# relaxgg-db4 (2f1ed7ad-083d-4475-a713-a96f302d663a)
# Services: golem, MariaDB + exporter, PostgreSQL + exporter, Redis + exporter, node-exporter, cadvisor

{% set mariadb_data_dir = "/data/mysql" %}
{% set mariadb_extra_volumes = ["/opt/services/config/mariadb/relaxgg-db4.cnf:/etc/mysql/conf.d/relaxgg-db4.cnf:ro"] %}
{% set mariadb_env_extra = {"MARIADB_AUTO_UPGRADE": "1"} %}
{% set mariadb_root_password = _2f1ed7ad_mariadb_root_password | default("kX9mPvL2wQnR7tYs4bHj") %}
{% set postgres_data_dir = "/data/postgresql" %}
{% set postgresql_root_password = _2f1ed7ad_postgresql_root_password | default(mariadb_root_password) %}
{% set redis_data_dir = "/data/redis" %}
{% set redis_port = "6379" %}
{% set redis_exporter_port = "9121" %}
{% set redis_password = _2f1ed7ad_redis_password %}
{% set elasticsearch_data_dir = "/data/elasticsearch" %}
{% set elasticsearch_password = _2f1ed7ad_elasticsearch_password %}
{% set elasticsearch_env = {"ES_JAVA_OPTS": "-Xms24g -Xmx24g", "cluster.name": "relaxgg-db4"} %}

services:
  # === DATABASES ===
  postgresql:
    image: postgres:16
    container_name: postgresql
    restart: always
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: {{ postgresql_root_password }}
    volumes:
      - {{ postgres_data_dir }}:/var/lib/postgresql/data
    ports:
      - "5432:5432"

{% include "services/mariadb.yml.j2" %}

{% set mysqld_exporter_dsn = "root:" ~ mariadb_root_password ~ "@(127.0.0.1:3306)/" %}
{% set mysqld_exporter_port = "9104" %}
{% include "services/mysqld-exporter.yml.j2" %}

  postgres-exporter:
    image: prometheuscommunity/postgres-exporter:latest
    container_name: postgres-exporter
    restart: always
    environment:
      DATA_SOURCE_NAME: "postgresql://postgres:{{ postgresql_root_password }}@127.0.0.1:5432/postgres?sslmode=disable"
    ports:
      - "9187:9187"
    network_mode: host
    depends_on:
      - postgresql

{% set redis_port_bindings = ["6379:6379"] %}
{% include "services/redis.yml.j2" %}

  elasticsearch:
{% include "services/elasticsearch.yml.j2" %}

{% set elasticsearch_host = "127.0.0.1" %}
{% set elasticsearch_port = "9200" %}
{% include "services/elasticsearch-exporter.yml.j2" %}

  # === INFRA ===
{% include "services/cadvisor.yml.j2" %}
{% include "services/node-exporter.yml.j2" %}
{% include "services/golem.yml.j2" %}
