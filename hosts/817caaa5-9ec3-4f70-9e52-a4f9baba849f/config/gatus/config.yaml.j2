storage:
  type: sqlite
  path: /data/data.db

web:
  port: 8080
  address: 0.0.0.0

endpoints:
  - name: gatus-self
    group: infra
    url: http://localhost:8080/health
    interval: 60s
    conditions:
      - "[STATUS] == 200"

  - name: prometheus
    group: infra
    url: http://prometheus:9090/-/ready
    interval: 30s
    conditions:
      - "[STATUS] == 200"

  - name: grafana
    group: infra
    url: http://grafana:3000/login
    interval: 30s
    conditions:
      - "[STATUS] == 200"

  - name: blackbox
    group: infra
    url: http://blackbox-exporter:9115/metrics
    interval: 30s
    conditions:
      - "[STATUS] == 200"
