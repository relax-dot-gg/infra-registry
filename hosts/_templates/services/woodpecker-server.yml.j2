  woodpecker-server:
    image: woodpeckerci/woodpecker-server:v3.12.0
    container_name: woodpecker-server
    restart: always
    network_mode: host
    volumes:
      - /opt/services/woodpecker/data:/var/lib/woodpecker
    environment:
      - WOODPECKER_SERVER_ADDR=:8000
      - WOODPECKER_GRPC_ADDR=:9000
      - WOODPECKER_HOST={{ woodpecker_host | default("http://localhost:8000") }}
      - WOODPECKER_ADMIN={{ woodpecker_admin | default("allenday") }}
      - WOODPECKER_OPEN=true
      - WOODPECKER_GITHUB=true
      - WOODPECKER_GITHUB_CLIENT={{ woodpecker_github_client }}
      - WOODPECKER_GITHUB_SECRET={{ woodpecker_github_secret }}
      - WOODPECKER_AGENT_SECRET={{ woodpecker_agent_secret }}
      - WOODPECKER_LOG_LEVEL=warn
      - WOODPECKER_REPO_OWNERS={{ woodpecker_repo_owners | default("allenday,cyberstorm-dev,fwh-ltd,relax-dot-gg,relayos,openclaw,relaxgg") }}
      - WOODPECKER_PLUGINS_PRIVILEGED=woodpeckerci/plugin-docker-buildx
      - WOODPECKER_DEFAULT_PIPELINE_TIMEOUT=120
      - WOODPECKER_DATABASE_DRIVER=postgres
      - WOODPECKER_DATABASE_DATASOURCE=postgresql://rw_woodpecker:{{ postgresql_rw_password_woodpecker }}@{{ woodpecker_database_host | default("infralink2.shrimp-crested.ts.net") }}:5432/woodpecker?sslmode=disable
