  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_SERVER_ROOT_URL=http://localhost:3001
      - GF_SERVER_HTTP_PORT=3001
    volumes:
      - /opt/infra/monitoring/data/grafana:/var/lib/grafana
      - /opt/infra/monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
      - /opt/infra/monitoring/grafana/dashboards:/etc/grafana/dashboards:ro
    ports:
      - "3001:3001"
