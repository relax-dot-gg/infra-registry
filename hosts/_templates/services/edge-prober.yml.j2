  edge-prober:
    image: ghcr.io/relax-dot-gg/edge-prober:latest
    container_name: edge-prober
    restart: unless-stopped
    network_mode: host
    environment:
      - EDGES_PATH=/edges/edges.json
      - PROBE_LISTEN=:8080
      - PROBE_INTERVAL=30s
      - PROBE_TIMEOUT=10s
    volumes:
      - /opt/infra/edge-prober:/edges:ro
