golem:
    image: ghcr.io/cyberstorm-dev/golem:latest
    container_name: golem
    restart: unless-stopped
    entrypoint:
      - /bin/sh
      - -c
      - |
        set -euo pipefail
        DEFAULT_LEDGER_REPO="https://100.73.228.90:3000/relaxgg/golem-ledger.git"
        LEDGER_REPO="$${LEDGER_REPO:-$${DEFAULT_LEDGER_REPO}}"

        LEDGER_SECRET=""
        if [ -n "$${GOLEM_DEPLOY_KEY_B64:-}" ]; then
          LEDGER_SECRET=$$(echo "$${GOLEM_DEPLOY_KEY_B64}" | base64 -d)
        fi

        # SSH-style URLs use the decoded key; HTTPS uses a token header
        if printf "%s" "$${LEDGER_REPO}" | grep -Eq '^git@|^ssh://'; then
          mkdir -p /run/secrets
          printf "%s" "$${LEDGER_SECRET}" > /run/secrets/deploy_key
          chmod 600 /run/secrets/deploy_key
          export GIT_SSH_COMMAND="ssh -i /run/secrets/deploy_key -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
        else
          export GITEA_TOKEN="$${LEDGER_SECRET}"
        fi

        BRANCH_NAME="$${NODE_NAME:-}"
        if [ -z "$${BRANCH_NAME}" ] && [ -f /etc/machine-uuid ]; then
          BRANCH_NAME=$$(cat /etc/machine-uuid)
        fi
        if [ -z "$${BRANCH_NAME}" ]; then
          BRANCH_NAME=$$(hostname)
        fi

        git config --global --add safe.directory /ledger
        exec /opt/golem/entrypoint.sh "$${LEDGER_REPO}" "$${BRANCH_NAME}"
    environment:
      LEDGER_DIR: /ledger
      POLL_INTERVAL: "3"
      GIT_REMOTE: origin
      GIT_USER_NAME: "relaxgg-devops"
      GIT_USER_EMAIL: "devops@relax.gg"
      GOLEM_DEPLOY_KEY_B64: "{{ golem_ledger_deploy_key_b64 }}"
    volumes:
      - /opt/services/golem/ledger:/ledger
      - /etc/machine-uuid:/etc/machine-uuid:ro
      - /var/run/docker.sock:/var/run/docker.sock
      - /:/host:rw
    network_mode: host
    pid: host
