  golem:
    image: ghcr.io/cyberstorm-dev/golem:latest
    container_name: golem
    restart: unless-stopped
    entrypoint:
      - /bin/sh
      - -c
      - |
        set -euo pipefail
        mkdir -p /run/secrets /etc/golem
        echo "$${GOLEM_DEPLOY_KEY_B64}" | base64 -d > /run/secrets/deploy_key
        chmod 600 /run/secrets/deploy_key
        echo "$${GOLEM_ALLOWED_SIGNERS_B64}" | base64 -d > /etc/golem/allowed_signers
        git config --global --add safe.directory /ledger
        exec /opt/golem/entrypoint.sh
    environment:
      LEDGER_DIR: /ledger
      LEDGER_REPO: "ssh://git@100.73.228.90:2222/relaxgg/golem-ledger.git"
      POLL_INTERVAL: "3"
      GIT_REMOTE: origin
      GIT_USER_NAME: "relaxgg-devops"
      GIT_USER_EMAIL: "devops@relax.gg"
      GIT_SSH_COMMAND: "ssh -i /run/secrets/deploy_key -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
      GOLEM_DEPLOY_KEY_B64: "{{ golem_ledger_deploy_key_b64 }}"
      GOLEM_ALLOWED_SIGNERS_B64: "{{ golem_allowed_signers_b64 }}"
    volumes:
      - /opt/services/golem/ledger:/ledger
      - /etc/machine-uuid:/etc/machine-uuid:ro
      - /var/run/docker.sock:/var/run/docker.sock
      - /:/host:rw
    network_mode: host
    pid: host
