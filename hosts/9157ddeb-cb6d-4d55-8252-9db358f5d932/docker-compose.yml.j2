# cyberstorm-woodpecker (9157ddeb-cb6d-4d55-8252-9db358f5d932)
# Woodpecker CI server + agent + Cloudflare tunnel + Postgres/Redis data layer

{% set postgres_data_dir = '/opt/services/postgresql/data' %}
{% set redis_data_dir = '/opt/services/redis/data' %}
{% set redis_port = '6379' %}
{% set redis_exporter_port = '9121' %}
{% set redis_password = _9157ddeb_redis_password %}
{% set golem_ledger_repo_url = 'http://' ~ _9157ddeb_gitea_token ~ '@100.73.228.90:3000/relaxgg/golem-ledger.git' %}

services:
  nginx:
    image: ghcr.io/relax-dot-gg/nginx:latest
    restart: always
    network_mode: host
    environment:
      - NGINX_ALLOW_LEGACY_CONF=1
      - CERT_B64={{ cyberstorm_origin_cert | default('', true) }}
      - KEY_B64={{ cyberstorm_origin_key | default('', true) }}
    command: >
      /bin/sh -c '
      if [ ! -f /etc/nginx/certs/cert.pem ] || [ ! -f /etc/nginx/certs/key.pem ]; then
        mkdir -p /etc/nginx/certs && \
        echo "$CERT_B64" | base64 -d > /etc/nginx/certs/cert.pem && \
        echo "$KEY_B64"  | base64 -d > /etc/nginx/certs/key.pem;
      fi;
      chown -R nginx:nginx /etc/nginx/certs && chmod 640 /etc/nginx/certs/key.pem;
      nginx -g "daemon off.";
      '
    volumes:
      - ./config/nginx/conf.d:/etc/nginx/conf.d:ro
      - ./config/nginx/certs:/etc/nginx/certs
    depends_on:
      - gitea
      - woodpecker-server

  cloudflared:
    image: cloudflare/cloudflared:latest
    restart: always
    network_mode: host
    command: tunnel --protocol http2 run
    environment:
      - TUNNEL_TOKEN={{ _9157ddeb_cloudflare_tunnel }}

  # === DATA LAYER ===
  postgresql:
    image: postgres:16
    container_name: postgresql
    restart: always
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: {{ _9157ddeb_postgresql_admin_password }}
    volumes:
      - {{ postgres_data_dir }}:/var/lib/postgresql/data
      - /opt/services/config/postgres/init.sql:/docker-entrypoint-initdb.d/10-init.sql:ro
    ports:
      - "5432:5432"

  postgres-exporter:
    image: prometheuscommunity/postgres-exporter:latest
    container_name: postgres-exporter
    restart: always
    environment:
      DATA_SOURCE_NAME: "postgresql://postgres:{{ _9157ddeb_postgresql_admin_password }}@127.0.0.1:5432/postgres?sslmode=disable"
    ports:
      - "9187:9187"
    network_mode: host
    depends_on:
      - postgresql

{% set redis_port_bindings = ['6379:6379'] %}
{% include "services/redis.yml.j2" %}

  # === CI ===
  woodpecker-server:
    image: woodpeckerci/woodpecker-server:v3.13.0
    user: root
    restart: always
    network_mode: host
    volumes:
      - ./data:/var/lib/woodpecker/
    environment:
      - WOODPECKER_FORGE_MULTI=true
      - WOODPECKER_SERVER_ADDR=0.0.0.0:8000
      - WOODPECKER_GRPC_ADDR=0.0.0.0:9000
      - WOODPECKER_HOST=https://woodpecker.relax.gg
      - WOODPECKER_ADMIN=allenday
      - WOODPECKER_OPEN=true
      - WOODPECKER_GITHUB=true
      - WOODPECKER_GITHUB_CLIENT={{ github_client }}
      - WOODPECKER_GITHUB_SECRET={{ github_secret }}
      - WOODPECKER_GITEA=true
      - WOODPECKER_GITEA_URL=http://100.73.228.90:3000/
      - WOODPECKER_GITEA_CLIENT={{ _9157ddeb_gitea_client_id | default('', true) }}
      - WOODPECKER_GITEA_SECRET={{ _9157ddeb_gitea_client_secret | default('', true) }}
      - WOODPECKER_AGENT_SECRET={{ _9157ddeb_agent_secret }}
      - WOODPECKER_LOG_LEVEL=warn
      - WOODPECKER_REPO_OWNERS=allenday,cyberstorm-dev,fwh-ltd,relax-dot-gg,relayos
      - WOODPECKER_PLUGINS_PRIVILEGED=woodpeckerci/plugin-docker-buildx
      - WOODPECKER_DEFAULT_PIPELINE_TIMEOUT=120
      - WOODPECKER_DATABASE_DRIVER=postgres
      - WOODPECKER_DATABASE_DATASOURCE={{ _9157ddeb_woodpecker_database_url }}
      - GITEA_URL=http://100.73.228.90:3000/
      - WOODPECKER_ENVIRONMENT=GITEA_TOKEN:{{ _9157ddeb_gitea_token }}
    # No healthcheck - distroless image has no shell

  woodpecker-agent:
    image: woodpeckerci/woodpecker-agent:v3.13.0
    restart: always
    network_mode: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - WOODPECKER_SERVER=127.0.0.1:9000
      - WOODPECKER_AGENT_SECRET={{ _9157ddeb_agent_secret }}
      - WOODPECKER_MAX_WORKFLOWS=2
      - WOODPECKER_PLUGINS_PRIVILEGED=woodpeckerci/plugin-docker-buildx
      - WOODPECKER_HEALTHCHECK_ADDR=:3001
      - GITEA_URL=http://100.73.228.90:3000/
      - WOODPECKER_ENVIRONMENT=GITEA_TOKEN:{{ _9157ddeb_gitea_token }}
    # No healthcheck - distroless image has no shell
    depends_on:
      - woodpecker-server

  # === GITEA (self-hosted git) ===
  gitea:
    image: gitea/gitea:1.25.4
    container_name: gitea
    restart: always
    environment:
      - USER_UID=1000
      - USER_GID=1000
      - GITEA__database__DB_TYPE=sqlite3
      - GITEA__database__PATH=/data/gitea.db
      - GITEA__server__DOMAIN=100.73.228.90
      - GITEA__server__ROOT_URL=http://100.73.228.90:3000/
      - GITEA__server__HTTP_ADDR=0.0.0.0
      - GITEA__server__HTTP_PORT=3000
      - GITEA__server__SSH_DOMAIN=100.73.228.90
      - GITEA__server__SSH_PORT=2222
      - GITEA__server__SSH_LISTEN_PORT=2222
      - GITEA__service__DISABLE_REGISTRATION=true
      - GITEA__security__INSTALL_LOCK=true
      - GITEA__security__SECRET_KEY={{ _9157ddeb_gitea_secret_key }}
      - GITEA__security__INTERNAL_TOKEN={{ _9157ddeb_gitea_internal_token }}
      - GITEA__security__JWT_SECRET={{ _9157ddeb_gitea_jwt_secret }}
      - GITEA_ADMIN_USERNAME=admin
      - GITEA_ADMIN_PASSWORD={{ _9157ddeb_gitea_admin_password }}
      - GITEA_ADMIN_EMAIL=devops-sa@relax.gg
      - GITEA_ADMIN_FULL_NAME=RelaxGG Admin
      - GITEA__log__MODE=console
      - GITEA__repository.signing__SIGNING_FORMAT=ssh
      - GITEA__repository.signing__INITIAL_COMMIT=always
      - GITEA__repository.signing__MERGES=pubkey, basesigned, commitssigned
      - GITEA__metrics__ENABLED=true
      - GITEA__metrics__ENABLED_ISSUE_BY_LABEL=true
      - GITEA__metrics__ENABLED_ISSUE_BY_REPOSITORY=true
    volumes:
      - ./gitea:/data
    ports:
      - "100.73.228.90:3000:3000"
      - "100.73.228.90:2222:22"

  # === OBSERVABILITY ===
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    restart: always
    command:
      - '--path.rootfs=/host'
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
      - '--collector.textfile.directory=/var/lib/node_exporter/textfile_collector'
      - '--web.config.file=/etc/node_exporter/web.config.yml'
    volumes:
      - /:/host:ro,rslave
      - /var/lib/node_exporter/textfile_collector:/var/lib/node_exporter/textfile_collector:ro
    network_mode: host
    pid: host

  statsd-exporter:
    image: prom/statsd-exporter:v0.26.0
    container_name: statsd-exporter
    restart: always
    ports:
      - "9102:9102"
      - "9125:9125/udp"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:9102/metrics"]
      interval: 30s
      timeout: 10s
      retries: 3

{% include "services/edge-prober.yml.j2" %}

{% include "services/golem.yml.j2" %}
