{
  "meta": {
    "lastTouchedVersion": "2026.1.30",
    "lastTouchedAt": "{{ values.lastTouchedAt | default('') }}"
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "every": "30m"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "models": {
        "anthropic/claude-opus-4-5": {
          "alias": "opus"
        }
      }
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      },
      "chrome": {
        "driver": "extension",
        "cdpUrl": "http://127.0.0.1:18792",
        "color": "#00AA00"
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "{{ _openclaw_gateway_token }}"
    },
    "controlUi": {
      "allowInsecureAuth": true
    }
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "wizard": {
    "lastRunAt": "{{ values.lastRunAt | default('') }}",
    "lastRunVersion": "2026.1.30",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  }
}
