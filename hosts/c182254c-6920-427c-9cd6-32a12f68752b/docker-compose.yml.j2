services:
  nginx:
    image: ghcr.io/relax-dot-gg/nginx:latest
    container_name: nginx
    restart: always
    ports:
      - "80:80"
      - "8080:8080"
    volumes:
      - ./config/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./config/nginx/conf.d:/etc/nginx/conf.d:ro
      - /opt/services/nginx/certs:/etc/nginx/certs:ro
      - /opt/services/log/nginx:/var/log/nginx
      - /opt/static-sites:/srv/static-sites:ro
      - /opt/static-sites-prod/sites:/srv/static-sites-prod:ro
      - /opt/static-sites-nonprod/sites:/srv/static-sites-nonprod:ro
      - /opt/static-sites/blobs:/srv/static-blobs:ro

  logrotate:
    image: alpine:3.20
    container_name: logrotate
    restart: always
    depends_on:
      - nginx
    volumes:
      - /opt/services/log/nginx:/var/log/nginx
      - ./config/logrotate/logrotate.conf:/etc/logrotate.conf:ro
      - ./config/logrotate/logrotate.d:/etc/logrotate.d:ro
      - /opt/services/logrotate-state:/var/lib/logrotate
    command: /bin/sh -c "apk add --no-cache logrotate >/dev/null && while true; do logrotate /etc/logrotate.conf; sleep ${LOGROTATE_INTERVAL:-86400}; done"

  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    restart: unless-stopped
    command: tunnel run
    network_mode: host
    environment:
      - TUNNEL_TOKEN={{ _c182254c_cloudflare_tunnel_token }}

  cloudflared-status:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared-status
    restart: always
    command: tunnel --no-autoupdate run
    network_mode: host
    environment:
      - TUNNEL_TOKEN={{ _c182254c_cloudflare_tunnel_token }}

{% include "services/node-exporter.yml.j2" %}
{% include "services/edge-prober.yml.j2" %}
