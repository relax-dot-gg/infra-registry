services:
{% set elasticsearch_data_dir = '/opt/services/data/elasticsearch' %}
{% set elasticsearch_security_enabled = false %}
{% set elasticsearch_discovery_type = 'single-node' %}
{% set elasticsearch_env = {
  'cluster.name': 'infralink-dev',
  'node.name': 'infralink4',
  'network.host': '0.0.0.0',
  'ES_JAVA_OPTS': '-Xms512m -Xmx512m'
} %}
{% include "services/elasticsearch.yml.j2" %}
{% set elasticsearch_host = '127.0.0.1' %}
{% set elasticsearch_port = '9200' %}
{% include "services/elasticsearch-exporter.yml.j2" %}

  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.106.0
    container_name: otel-collector
    restart: unless-stopped
    command: ["--config=/etc/otelcol/config.yaml"]
    volumes:
      - /opt/services/config/otel-collector/config.yaml:/etc/otelcol/config.yaml:ro
    ports:
      - "4317:4317"
      - "4318:4318"
      - "9464:9464"

  nginx:
    image: ghcr.io/relax-dot-gg/nginx:latest
    container_name: nginx
    restart: always
    network_mode: host
    volumes:
      - ./config/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./config/nginx/conf.d:/etc/nginx/conf.d:ro

{% set nginx_vts_scrape_uri = 'http://127.0.0.1:8081/status' %}
{% include "services/nginx-vts-exporter.yml.j2" %}
{% include "services/node-exporter.yml.j2" %}
{% include "services/cadvisor.yml.j2" %}
{% include "services/edge-prober.yml.j2" %}
{% include "services/golem.yml.j2" %}
