services:
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    restart: always
    command:
      - '--path.rootfs=/host'
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
      - '--web.config.file=/etc/node_exporter/web.config.yml'
    volumes:
      - /:/host:ro,rslave
      - ./config/node_exporter/web.config.yml:/etc/node_exporter/web.config.yml:ro
    ports:
      - "9100:9100"
    network_mode: host
    pid: host
{% include '_templates/services/postfix-exporter.yml.j2' %}
{% include '_templates/services/certbot.yml.j2' %}
{% for inst in postfix_instances %}
{% set service_name = inst.service_name %}
{% set primary_domain = inst.primary_domain %}
{% set relay_ip = inst.relay_ip %}
{% set main_cf_path = inst.main_cf_path %}
{% set spool_path = inst.spool_path %}
{% set opendkim_path = inst.get('opendkim_path', '') %}
{% set fullchain_path = inst.fullchain_path %}
{% set privkey_path = inst.privkey_path %}
{% set users_path = inst.users_path %}
{% set smtp_port = inst.get('smtp_port', '') %}
{% set submission_port = inst.get('submission_port', '') %}
{% set smtp_bind_address = inst.get('smtp_bind_address', '') %}
{% include '_templates/services/postfix/base.yml.j2' %}
{% endfor %}
