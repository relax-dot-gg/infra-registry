# bdsmlr-cdn-034 (8c4894b2-63fc-472c-b10f-1e0fd94a2947)

{% set acme_domains = ['cdn012.bdsmlr.com', 'cdn013.bdsmlr.com', 'cdn101.bdsmlr.com'] %}
{% set acme_dns_provider = 'cloudflare' %}
{% set acme_dns_token = cloudflare_edit_dns_bdsmlr %}

services:
  nginx:
    image: ghcr.io/relax-dot-gg/nginx:latest
    container_name: nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "8081:8081"
    volumes:
      - ./config/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./config/conf.d:/etc/nginx/conf.d:ro
      - ./config/nginx/certs:/etc/nginx/certs:ro
    depends_on:
      - lego
      - imageproxy

{% include "services/lego-dns.yml.j2" %}
{% include "services/imageproxy.yml.j2" %}
{% include "services/cadvisor.yml.j2" %}
{% include "services/node-exporter.yml.j2" %}
{% include "services/nginx-vts-exporter.yml.j2" %}
