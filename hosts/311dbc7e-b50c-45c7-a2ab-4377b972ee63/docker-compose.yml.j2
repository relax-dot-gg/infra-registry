services:
  nginx:
    image: ghcr.io/relax-dot-gg/nginx:latest
    container_name: nginx
    restart: always
    network_mode: host
    volumes:
      - ./config/nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./config/nginx/conf.d:/etc/nginx/conf.d:ro
      - ./config/nginx/cloudflare-only.conf:/etc/nginx/cloudflare-only.conf:ro
      - /var/www/html:/var/www/html:ro
      - /var/www/subdomains:/var/www/subdomains:ro
      - /var/www/letsencrypt:/var/www/letsencrypt:ro
      - /var/run/php:/var/run/php
      - /etc/ssl:/etc/ssl:ro
{% set nginx_vts_scrape_uri = 'http://127.0.0.1:8081/status' %}
{% include "services/nginx-vts-exporter.yml.j2" %}
  php-fpm:
    image: ghcr.io/relax-dot-gg/php:7.4-fpm
    container_name: php-fpm
    restart: always
    volumes:
      - /var/www/html:/var/www/html
      - /var/www/subdomains:/var/www/subdomains
  node-exporter:
    image: prom/node-exporter:latest
    container_name: node-exporter
    restart: always
    command:
      - '--path.rootfs=/host'
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)'
      - '--web.config.file=/etc/node_exporter/web.config.yml'
    volumes:
      - /:/host:ro,rslave
      - ./config/node_exporter/web.config.yml:/etc/node_exporter/web.config.yml:ro
    ports:
      - "9100:9100"
    network_mode: host
    pid: host
{% set redis_password = _311dbc7e_redis_password %}
{% set redis_exporter_port = '9121' %}
{% set redis_port = '6379' %}
{% set redis_config_path = '/opt/services/config/redis/redis.conf' %}
{% set redis_config_container_path = '/etc/redis/redis.conf' %}
{% include "services/redis.yml.j2" %}
{% set php_fpm_fastcgi = 'unix:///var/run/php/php7.4-fpm.sock' %}
{% include "services/php-fpm-exporter.yml.j2" %}
{% include "services/cadvisor.yml.j2" %}
{% include "services/edge-prober.yml.j2" %}
